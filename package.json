{
  "name": "sveltekit-editorial",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "contentrain:generate": "contentrain generate",
    "deploy:vercel": "pnpm build",
    "deploy:netlify": "pnpm build",
    "deploy:cloudflare": "pnpm build"
  },
  "dependencies": {
    "@contentrain/query": "^5.0.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.48.3",
    "svelte": "^5.38.6"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "contentrain": "^0.2.3",
    "svelte-check": "^4.3.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "imports": {
    "#contentrain": {
      "types": "./.contentrain/client/index.d.ts",
      "import": "./.contentrain/client/index.mjs",
      "require": "./.contentrain/client/index.cjs"
    },
    "#contentrain/*": {
      "types": "./.contentrain/client/*.d.ts",
      "import": "./.contentrain/client/*.mjs",
      "require": "./.contentrain/client/*.cjs"
    }
  }
}
